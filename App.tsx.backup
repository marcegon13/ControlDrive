                  styles.textoApp,
                  billeteraId === b.id && styles.textoAppSeleccionado
                ]}>
                  {b.icono} {b.nombre}
                </Text>
              </TouchableOpacity>
            ))}
          </ScrollView>

          {/* BOTONES */}
