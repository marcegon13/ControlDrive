// App.tsx - CONTROL DRIVER COMPLETO CON BILLETERAS RESETEADAS
import React, { useState, useEffect } from 'react';
import {
  View,
  Text,
  TextInput,
  TouchableOpacity,
  FlatList,
  Modal,
  StyleSheet,
  SafeAreaView,
  ScrollView,
  Alert,
  Platform,
} from 'react-native';
import AsyncStorage from '@react-native-async-storage/async-storage';
import { Calendar } from 'react-native-calendars';

// ==================== TIPOS DE DATOS ====================
interface Billetera {
  id: string;
  nombre: string;
  saldo: number;
  color: string;
  icono: string;
}

interface RegistroDiario {
  id: string;
  app: string;
  efectivo: number;
  tarjetas: number;
  mercadoPago: number;
  total: number;
  fecha: Date;
  fechaRegistro: Date;
}

interface CargaCombustible {
  id: string;
  estacion: string;
  total: number;
  litros: number;
  precioPorLitro: number;
  billeteraId: string;
  fecha: Date;
  fechaRegistro: Date;
}

interface IngresoGeneral {
  id: string;
  monto: number;
  descripcion: string;
  billeteraId: string;
  fecha: Date;
  fechaRegistro: Date;
}

interface GastoGeneral {
  id: string;
  monto: number;
  descripcion: string;
  categoria: string;
  billeteraId: string;
  fecha: Date;
  fechaRegistro: Date;
}

interface Proyeccion {
  promedioDiario: number;
  diasRestantes: number;
  proyeccionMensual: number;
  gananciaProyectada: number;
  mensaje: string;
}

// ==================== CONSTANTES ====================
const BILLETERAS_INICIALES: Billetera[] = [
  { id: '1', nombre: 'Efectivo', saldo: 0.00, color: '#27ae60', icono: '💵' },
  { id: '2', nombre: 'Tarjetas/Plataforma', saldo: 0.00, color: '#3498db', icono: '💳' },
  { id: '3', nombre: 'Mercado Pago', saldo: 0.00, color: '#9b59b6', icono: '📱' },
];

const APPS_DISPONIBLES = ['Uber', 'Didi', 'Cabify', 'Beat', 'InDrive', 'Otro'];
const ESTACIONES_DISPONIBLES = ['YPF', 'SHELL', 'AXION', 'PUMA', 'OTRA'];
const CATEGORIAS_GASTOS = ['Comida', 'Transporte', 'Servicios', 'Impuestos', 'Mantenimiento', 'Otros'];

const STORAGE_KEYS = {
  BILLETERAS: '@billeteras',
  REGISTROS: '@registrosDiarios',
  CARGAS: '@cargasCombustible',
  INGRESOS: '@ingresosGenerales',
  GASTOS: '@gastosGenerales',
};

// ==================== UTILIDADES ====================
const formatearMoneda = (monto: number): string => {
  return `$${monto.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',')}`;
};

const formatearFecha = (fecha: Date): string => {
  return fecha.toLocaleDateString('es-AR', {
    day: '2-digit',
    month: 'short',
    year: 'numeric'
  });
};

const obtenerDiasEnMes = (fecha: Date): number => {
  return new Date(fecha.getFullYear(), fecha.getMonth() + 1, 0).getDate();
};

// ==================== COMPONENTE: CALENDARIO PARA FECHAS ====================
interface SelectorFechaProps {
  visible: boolean;
  fechaInicial: Date;
  onSeleccionar: (fecha: Date) => void;
  onCancelar: () => void;
}

const SelectorFecha: React.FC<SelectorFechaProps> = ({
  visible,
  fechaInicial,
  onSeleccionar,
  onCancelar,
}) => {
  const [fechaSeleccionada, setFechaSeleccionada] = useState(
    fechaInicial.toISOString().split('T')[0]
  );

  return (
    <Modal visible={visible} transparent animationType="slide">
      <View style={styles.modalOverlay}>
        <View style={styles.modalContent}>
          <Text style={styles.modalTitle}>📅 Seleccionar Fecha</Text>
          
          <Calendar
            current={fechaSeleccionada}
            onDayPress={(day) => setFechaSeleccionada(day.dateString)}
            markedDates={{
              [fechaSeleccionada]: { selected: true, selectedColor: '#3498db' }
            }}
            theme={{
              selectedDayBackgroundColor: '#3498db',
              todayTextColor: '#e74c3c',
              arrowColor: '#3498db',
              monthTextColor: '#2c3e50',
              textMonthFontWeight: 'bold',
            }}
          />
          
          <View style={styles.modalButtons}>
            <TouchableOpacity style={styles.botonCancelar} onPress={onCancelar}>
              <Text style={styles.botonTexto}>Cancelar</Text>
            </TouchableOpacity>
            <TouchableOpacity 
              style={styles.botonConfirmar} 
              onPress={() => onSeleccionar(new Date(fechaSeleccionada))}
            >
              <Text style={[styles.botonTexto, { color: '#fff' }]}>Seleccionar</Text>
            </TouchableOpacity>
          </View>
        </View>
      </View>
    </Modal>
  );
};

// ==================== COMPONENTE: DASHBOARD DE LA IMAGEN ====================
interface DashboardProps {
  registros: RegistroDiario[];
  cargas: CargaCombustible[];
  billeteras: Billetera[];
  onAbrirViajes: () => void;
  onAbrirCombustible: () => void;
  onAbrirIngreso: () => void;
  onAbrirGasto: () => void;
  onResetearSaldos: () => void;
}

const Dashboard: React.FC<DashboardProps> = ({ 
  registros, 
  cargas, 
  billeteras,
  onAbrirViajes,
  onAbrirCombustible,
  onAbrirIngreso,
  onAbrirGasto,
  onResetearSaldos
}) => {
  // CÁLCULO DE ESTADÍSTICAS
  const calcularEstadisticas = () => {
    const hoy = new Date();
    hoy.setHours(0, 0, 0, 0);
    
    const inicioSemana = new Date(hoy);
    inicioSemana.setDate(hoy.getDate() - hoy.getDay());
    
    const inicioMes = new Date(hoy.getFullYear(), hoy.getMonth(), 1);

    // Filtrar registros por período
    const registrosHoy = registros.filter(r => {
      const fechaReg = new Date(r.fecha);
      fechaReg.setHours(0, 0, 0, 0);
      return fechaReg.getTime() === hoy.getTime();
    });

    const registrosSemana = registros.filter(r => {
      const fechaReg = new Date(r.fecha);
      return fechaReg >= inicioSemana;
    });

    const registrosMes = registros.filter(r => {
      const fechaReg = new Date(r.fecha);
      return fechaReg >= inicioMes;
    });

    // Filtrar cargas por período
    const cargasHoy = cargas.filter(c => {
      const fechaCarga = new Date(c.fecha);
      fechaCarga.setHours(0, 0, 0, 0);
      return fechaCarga.getTime() === hoy.getTime();
    });

    const cargasSemana = cargas.filter(c => {
      const fechaCarga = new Date(c.fecha);
      return fechaCarga >= inicioSemana;
    });

    const cargasMes = cargas.filter(c => {
      const fechaCarga = new Date(c.fecha);
      return fechaCarga >= inicioMes;
    });

    // Calcular totales
    const hoyIngresos = registrosHoy.reduce((sum, r) => sum + r.total, 0);
    const hoyGastos = cargasHoy.reduce((sum, c) => sum + c.total, 0);
    const hoyNeto = hoyIngresos - hoyGastos;
    
    const semanaIngresos = registrosSemana.reduce((sum, r) => sum + r.total, 0);
    const semanaGastos = cargasSemana.reduce((sum, c) => sum + c.total, 0);
    const semanaNeto = semanaIngresos - semanaGastos;
    
    const mesIngresos = registrosMes.reduce((sum, r) => sum + r.total, 0);
    const mesGastos = cargasMes.reduce((sum, c) => sum + c.total, 0);
    const mesNeto = mesIngresos - mesGastos;

    // Calcular porcentajes
    const hoyPorcentaje = hoyIngresos > 0 ? (hoyNeto / hoyIngresos) * 100 : 0;
    const semanaPorcentaje = semanaIngresos > 0 ? (semanaNeto / semanaIngresos) * 100 : 0;
    const mesPorcentaje = mesIngresos > 0 ? (mesNeto / mesIngresos) * 100 : 0;

    return {
      hoy: {
        ingresos: hoyIngresos,
        gastos: hoyGastos,
        neto: hoyNeto,
        porcentaje: hoyPorcentaje
      },
      semana: {
        ingresos: semanaIngresos,
        gastos: semanaGastos,
        neto: semanaNeto,
        porcentaje: semanaPorcentaje
      },
      mes: {
        ingresos: mesIngresos,
        gastos: mesGastos,
        neto: mesNeto,
        porcentaje: mesPorcentaje
      }
    };
  };

  // CÁLCULO DE PROYECCIONES
  const calcularProyecciones = (): Proyeccion => {
    const hoy = new Date();
    const diasEnMes = obtenerDiasEnMes(hoy);
    const diaActual = hoy.getDate();
    const diasRestantes = diasEnMes - diaActual;
    
    const stats = calcularEstadisticas();
    const promedioDiario = stats.mes.ingresos / diaActual;
    const proyeccionMensual = promedioDiario * diasEnMes;
    const gananciaProyectada = proyeccionMensual * (stats.mes.porcentaje / 100);
    
    return {
      promedioDiario,
      diasRestantes,
      proyeccionMensual,
      gananciaProyectada,
      mensaje: `Si seguís así, este mes ganarás: ${formatearMoneda(gananciaProyectada)}`
    };
  };

  const stats = calcularEstadisticas();
  const proyeccion = calcularProyecciones();

  return (
    <ScrollView style={styles.dashboardContainer}>
      {/* TÍTULO */}
      <View style={styles.header}>
        <Text style={styles.tituloPrincipal}>Control Driver</Text>
      </View>

      {/* ACUMULADO POR PERÍODO - TABLA CORREGIDA Y CENTRADA */}
      <View style={styles.seccion}>
        <Text style={styles.tituloSeccion}>Acumulado por Período</Text>
        
        <View style={styles.tablaContainer}>
          {/* ENCABEZADOS */}
          <View style={styles.filaTabla}>
            <View style={styles.columnaHeader}>
              <Text style={styles.encabezadoTabla}>Hoy</Text>
            </View>
            <View style={styles.columnaHeader}>
              <Text style={styles.encabezadoTabla}>Semana</Text>
            </View>
            <View style={styles.columnaHeader}>
              <Text style={styles.encabezadoTabla}>Mes</Text>
            </View>
          </View>
          
          {/* VALORES TOTALES */}
          <View style={styles.filaTabla}>
            <View style={styles.columnaValor}>
              <Text style={styles.valorTotal}>+{formatearMoneda(stats.hoy.ingresos)}</Text>
            </View>
            <View style={styles.columnaValor}>
              <Text style={styles.valorTotal}>+{formatearMoneda(stats.semana.ingresos)}</Text>
            </View>
            <View style={styles.columnaValor}>
              <Text style={styles.valorTotal}>+{formatearMoneda(stats.mes.ingresos)}</Text>
            </View>
          </View>
          
          {/* VALORES NETOS */}
          <View style={styles.filaTabla}>
            <View style={styles.columnaValor}>
              <Text style={[styles.valorNeto, { color: stats.hoy.neto >= 0 ? '#27ae60' : '#e74c3c' }]}>
                Neto: {formatearMoneda(stats.hoy.neto)}
              </Text>
            </View>
            <View style={styles.columnaValor}>
              <Text style={[styles.valorNeto, { color: stats.semana.neto >= 0 ? '#27ae60' : '#e74c3c' }]}>
                Neto: {formatearMoneda(stats.semana.neto)}
              </Text>
            </View>
            <View style={styles.columnaValor}>
              <Text style={[styles.valorNeto, { color: stats.mes.neto >= 0 ? '#27ae60' : '#e74c3c' }]}>
                Neto: {formatearMoneda(stats.mes.neto)}
              </Text>
            </View>
          </View>
          
          {/* PORCENTAJES */}
          <View style={[styles.filaTabla, { borderBottomWidth: 0 }]}>
            <View style={styles.columnaValor}>
              <Text style={styles.porcentaje}>
                {stats.hoy.porcentaje.toFixed(1)}%
              </Text>
            </View>
            <View style={styles.columnaValor}>
              <Text style={styles.porcentaje}>
                {stats.semana.porcentaje.toFixed(1)}%
              </Text>
            </View>
            <View style={styles.columnaValor}>
              <Text style={styles.porcentaje}>
                {stats.mes.porcentaje.toFixed(1)}%
              </Text>
            </View>
          </View>
        </View>
      </View>

      {/* PROYECCIONES */}
      <View style={styles.seccion}>
        <Text style={styles.tituloSeccion}>📈 Proyecciones</Text>
        
        <View style={styles.proyeccionCard}>
          <View style={styles.filaProyeccion}>
            <Text style={styles.labelProyeccion}>Promedio diario:</Text>
            <Text style={styles.valorProyeccion}>{formatearMoneda(proyeccion.promedioDiario)}</Text>
          </View>
          
          <View style={styles.filaProyeccion}>
            <Text style={styles.labelProyeccion}>Días restantes:</Text>
            <Text style={styles.valorProyeccion}>{proyeccion.diasRestantes}</Text>
          </View>
          
          <View style={styles.filaProyeccion}>
            <Text style={styles.labelProyeccion}>Proyección mensual:</Text>
            <Text style={styles.valorProyeccion}>{formatearMoneda(proyeccion.proyeccionMensual)}</Text>
          </View>
          
          <View style={styles.alertaProyeccion}>
            <Text style={styles.mensajeProyeccion}>Si seguís así, este mes ganarás:</Text>
            <Text style={styles.gananciaProyectada}>
              {formatearMoneda(proyeccion.gananciaProyectada)}
            </Text>
          </View>
        </View>
      </View>

      {/* ACCIONES RÁPIDAS - TODOS LOS BOTONES FUNCIONALES */}
      <View style={styles.seccion}>
        <Text style={styles.tituloSeccion}>Acciones Rápidas</Text>
        
        <View style={styles.gridAcciones}>
          <TouchableOpacity 
            style={styles.botonAccion}
            onPress={onAbrirIngreso}
          >
            <Text style={styles.iconoAccion}>💰</Text>
            <Text style={styles.textoAccion}>Ingreso</Text>
          </TouchableOpacity>
          
          <TouchableOpacity 
            style={styles.botonAccion}
            onPress={onAbrirGasto}
          >
            <Text style={styles.iconoAccion}>💳</Text>
            <Text style={styles.textoAccion}>Gasto</Text>
          </TouchableOpacity>
          
          <TouchableOpacity 
            style={styles.botonAccion}
            onPress={onAbrirViajes}
          >
            <Text style={styles.iconoAccion}>🚗</Text>
            <Text style={styles.textoAccion}>Viajes App</Text>
          </TouchableOpacity>
          
          <TouchableOpacity 
            style={styles.botonAccion}
            onPress={onAbrirCombustible}
          >
            <Text style={styles.iconoAccion}>⛽</Text>
            <Text style={styles.textoAccion}>Combustible</Text>
          </TouchableOpacity>
        </View>
      </View>

      {/* BILLETERAS CON BOTÓN DE RESET */}
      <View style={styles.seccion}>
        <View style={styles.headerBilleteras}>
          <Text style={styles.tituloSeccion}>Billeteras</Text>
          <TouchableOpacity 
            style={styles.botonResetMini}
            onPress={onResetearSaldos}
          >
            <Text style={styles.textoResetMini}>🔄 Reset</Text>
          </TouchableOpacity>
        </View>
        
        <View style={styles.listaBilleteras}>
          {billeteras.map((billetera) => (
            <View 
              key={billetera.id} 
              style={[
                styles.cardBilletera,
                billetera.saldo < 0 && styles.billeteraNegativa
              ]}
            >
              <View style={styles.filaBilletera}>
                <Text style={styles.iconoBilletera}>{billetera.icono}</Text>
                <View style={styles.infoBilletera}>
                  <Text style={styles.nombreBilletera}>{billetera.nombre}</Text>
                  <Text style={[
                    styles.saldoBilletera,
                    { color: billetera.saldo >= 0 ? '#27ae60' : '#e74c3c' }
                  ]}>
                    {formatearMoneda(billetera.saldo)}
                  </Text>
                </View>
                <TouchableOpacity 
                  style={styles.botonCero}
                  onPress={() => {
                    Alert.alert(
                      'Resetear saldo',
                      `¿Poner el saldo de ${billetera.nombre} en 0?`,
                      [
                        { text: 'Cancelar', style: 'cancel' },
                        {
                          text: 'Resetear',
                          onPress: () => {
                            // Esta función sería pasada como prop si necesitas modificar individualmente
                            onResetearSaldos();
                          }
                        }
                      ]
                    );
                  }}
                >
                  <Text style={styles.textoCero}>0</Text>
                </TouchableOpacity>
              </View>
            </View>
          ))}
        </View>
      </View>
    </ScrollView>
  );
};

// ==================== COMPONENTE: REGISTRO DE VIAJES ====================
interface RegistroViajesProps {
  visible: boolean;
  onGuardar: (registro: Omit<RegistroDiario, 'id' | 'fechaRegistro'>) => void;
  onCancelar: () => void;
}

const RegistroViajes: React.FC<RegistroViajesProps> = ({
  visible,
  onGuardar,
  onCancelar,
}) => {
  const [mostrarCalendario, setMostrarCalendario] = useState(false);
  const [fecha, setFecha] = useState(new Date());
  const [app, setApp] = useState('Uber');
  const [efectivo, setEfectivo] = useState('');
  const [tarjetas, setTarjetas] = useState('');
  const [mercadoPago, setMercadoPago] = useState('');

  const total = (parseFloat(efectivo) || 0) + 
                (parseFloat(tarjetas) || 0) + 
                (parseFloat(mercadoPago) || 0);

  const handleGuardar = () => {
    if (total <= 0) {
      Alert.alert('Error', 'El total debe ser mayor a 0');
      return;
    }

    onGuardar({
      app,
      efectivo: parseFloat(efectivo) || 0,
      tarjetas: parseFloat(tarjetas) || 0,
      mercadoPago: parseFloat(mercadoPago) || 0,
      total,
      fecha: new Date(fecha),
    });

    // Resetear formulario
    setEfectivo('');
    setTarjetas('');
    setMercadoPago('');
  };

  if (!visible) return null;

  return (
    <Modal visible={visible} transparent animationType="slide">
      <View style={styles.modalOverlay}>
        <View style={styles.modalContent}>
          <Text style={styles.modalTitle}>🚗 Registrar Viajes</Text>

          {/* SELECTOR DE FECHA */}
          <TouchableOpacity 
            style={styles.botonFecha}
            onPress={() => setMostrarCalendario(true)}
          >
            <Text style={styles.textoFecha}>📅 {formatearFecha(fecha)}</Text>
            <Text style={styles.textoCambiarFecha}>Cambiar fecha</Text>
          </TouchableOpacity>

          <SelectorFecha
            visible={mostrarCalendario}
            fechaInicial={fecha}
            onSeleccionar={(nuevaFecha) => {
              setFecha(nuevaFecha);
              setMostrarCalendario(false);
            }}
            onCancelar={() => setMostrarCalendario(false)}
          />

          {/* SELECTOR DE APP */}
          <Text style={styles.label}>App</Text>
          <ScrollView horizontal style={styles.listaApps}>
            {APPS_DISPONIBLES.map((appNombre) => (
              <TouchableOpacity
                key={appNombre}
                style={[
                  styles.botonApp,
                  app === appNombre && styles.botonAppSeleccionado
                ]}
                onPress={() => setApp(appNombre)}
              >
                <Text style={[
                  styles.textoApp,
                  app === appNombre && styles.textoAppSeleccionado
                ]}>
                  {appNombre}
                </Text>
              </TouchableOpacity>
            ))}
          </ScrollView>

          {/* INPUTS DE MONTO */}
          <Text style={styles.label}>💵 Efectivo</Text>
          <TextInput
            style={styles.input}
            value={efectivo}
            onChangeText={setEfectivo}
            placeholder="0.00"
            keyboardType="decimal-pad"
          />

          <Text style={styles.label}>💳 Tarjetas/Plataforma</Text>
          <TextInput
            style={styles.input}
            value={tarjetas}
            onChangeText={setTarjetas}
            placeholder="0.00"
            keyboardType="decimal-pad"
          />

          <Text style={styles.label}>📱 Mercado Pago</Text>
          <TextInput
            style={styles.input}
            value={mercadoPago}
            onChangeText={setMercadoPago}
            placeholder="0.00"
            keyboardType="decimal-pad"
          />

          {/* TOTAL */}
          <View style={styles.totalContainer}>
            <Text style={styles.totalLabel}>Total:</Text>
            <Text style={styles.totalValor}>{formatearMoneda(total)}</Text>
          </View>

          {/* BOTONES */}
          <View style={styles.modalButtons}>
            <TouchableOpacity style={styles.botonCancelar} onPress={onCancelar}>
              <Text style={styles.botonTexto}>Cancelar</Text>
            </TouchableOpacity>
            <TouchableOpacity style={styles.botonGuardar} onPress={handleGuardar}>
              <Text style={[styles.botonTexto, { color: '#fff' }]}>Guardar</Text>
            </TouchableOpacity>
          </View>
        </View>
      </View>
    </Modal>
  );
};

// ==================== COMPONENTE: REGISTRO DE COMBUSTIBLE ====================
interface RegistroCombustibleProps {
  visible: boolean;
  billeteras: Billetera[];
  onGuardar: (carga: Omit<CargaCombustible, 'id' | 'fechaRegistro'>) => void;
  onCancelar: () => void;
}

const RegistroCombustible: React.FC<RegistroCombustibleProps> = ({
  visible,
  billeteras,
  onGuardar,
  onCancelar,
}) => {
  const [mostrarCalendario, setMostrarCalendario] = useState(false);
  const [fecha, setFecha] = useState(new Date());
  const [estacion, setEstacion] = useState('YPF');
  const [total, setTotal] = useState('');
  const [litros, setLitros] = useState('');
  const [billeteraId, setBilleteraId] = useState(billeteras[0]?.id || '');

  const precioPorLitro = litros && total 
    ? (parseFloat(total) / parseFloat(litros)).toFixed(2)
    : '0.00';

  const handleGuardar = () => {
    const totalNum = parseFloat(total);
    const litrosNum = parseFloat(litros);

    if (!totalNum || !litrosNum || totalNum <= 0 || litrosNum <= 0) {
      Alert.alert('Error', 'Completa los campos correctamente');
      return;
    }

    onGuardar({
      estacion,
      total: totalNum,
      litros: litrosNum,
      precioPorLitro: parseFloat(precioPorLitro),
      billeteraId,
      fecha: new Date(fecha),
    });

    // Resetear
    setTotal('');
    setLitros('');
  };

  if (!visible) return null;

  return (
    <Modal visible={visible} transparent animationType="slide">
      <View style={styles.modalOverlay}>
        <View style={styles.modalContent}>
          <Text style={styles.modalTitle}>⛽ Registrar Combustible</Text>

          {/* SELECTOR DE FECHA */}
          <TouchableOpacity 
            style={styles.botonFecha}
            onPress={() => setMostrarCalendario(true)}
          >
            <Text style={styles.textoFecha}>📅 {formatearFecha(fecha)}</Text>
            <Text style={styles.textoCambiarFecha}>Cambiar fecha</Text>
          </TouchableOpacity>

          <SelectorFecha
            visible={mostrarCalendario}
            fechaInicial={fecha}
            onSeleccionar={(nuevaFecha) => {
              setFecha(nuevaFecha);
              setMostrarCalendario(false);
            }}
            onCancelar={() => setMostrarCalendario(false)}
          />

          {/* SELECTOR DE ESTACIÓN */}
          <Text style={styles.label}>Estación</Text>
          <ScrollView horizontal style={styles.listaApps}>
            {ESTACIONES_DISPONIBLES.map((est) => (
              <TouchableOpacity
                key={est}
                style={[
                  styles.botonApp,
                  estacion === est && styles.botonAppSeleccionado
                ]}
                onPress={() => setEstacion(est)}
              >
                <Text style={[
                  styles.textoApp,
                  estacion === est && styles.textoAppSeleccionado
                ]}>
                  {est}
                </Text>
              </TouchableOpacity>
            ))}
          </ScrollView>

          {/* BILLETERA DE PAGO */}
          <Text style={styles.label}>Billetera de Pago</Text>
          <ScrollView horizontal style={styles.listaApps}>
            {billeteras.map((b) => (
              <TouchableOpacity
                key={b.id}
                style={[
                  styles.botonApp,
                  billeteraId === b.id && styles.botonAppSeleccionado
                ]}
                onPress={() => setBilleteraId(b.id)}
              >
                <Text style={[
                  styles.textoApp,
                  billeteraId === b.id && styles.textoAppSeleccionado
                ]}>
                  {b.icono} {b.nombre}
                </Text>
              </TouchableOpacity>
            ))}
          </ScrollView>

          {/* INPUTS */}
          <View style={styles.filaInputs}>
            <View style={styles.inputMitad}>
              <Text style={styles.label}>Total ($)</Text>
              <TextInput
                style={styles.input}
                value={total}
                onChangeText={setTotal}
                placeholder="0.00"
                keyboardType="decimal-pad"
              />
            </View>
            
            <View style={styles.inputMitad}>
              <Text style={styles.label}>Litros</Text>
              <TextInput
                style={styles.input}
                value={litros}
                onChangeText={setLitros}
                placeholder="0.0"
                keyboardType="decimal-pad"
              />
            </View>
          </View>

          {/* PRECIO POR LITRO (CALCULADO) */}
          <Text style={styles.label}>Precio por Litro</Text>
          <TextInput
            style={[styles.input, styles.inputCalculado]}
            value={precioPorLitro}
            editable={false}
            placeholder="Calculado automáticamente"
          />

          {/* BOTONES */}
          <View style={styles.modalButtons}>
            <TouchableOpacity style={styles.botonCancelar} onPress={onCancelar}>
              <Text style={styles.botonTexto}>Cancelar</Text>
            </TouchableOpacity>
            <TouchableOpacity style={styles.botonGuardar} onPress={handleGuardar}>
              <Text style={[styles.botonTexto, { color: '#fff' }]}>Guardar</Text>
            </TouchableOpacity>
          </View>
        </View>
      </View>
    </Modal>
  );
};

// ==================== COMPONENTE: REGISTRO DE INGRESO GENERAL ====================
interface RegistroIngresoGeneralProps {
  visible: boolean;
  billeteras: Billetera[];
  onGuardar: (ingreso: {
    monto: number;
    descripcion: string;
    billeteraId: string;
    fecha: Date;
  }) => void;
  onCancelar: () => void;
}

const RegistroIngresoGeneral: React.FC<RegistroIngresoGeneralProps> = ({
  visible,
  billeteras,
  onGuardar,
  onCancelar,
}) => {
  const [mostrarCalendario, setMostrarCalendario] = useState(false);
  const [fecha, setFecha] = useState(new Date());
  const [descripcion, setDescripcion] = useState('');
  const [monto, setMonto] = useState('');
  const [billeteraId, setBilleteraId] = useState(billeteras[0]?.id || '');

  const handleGuardar = () => {
    const montoNum = parseFloat(monto);
    
    if (!montoNum || montoNum <= 0) {
      Alert.alert('Error', 'Ingresa un monto válido');
      return;
    }
    
    if (!descripcion.trim()) {
      Alert.alert('Error', 'Ingresa una descripción');
      return;
    }

    onGuardar({
      monto: montoNum,
      descripcion: descripcion.trim(),
      billeteraId,
      fecha: new Date(fecha),
    });

    // Resetear
    setDescripcion('');
    setMonto('');
  };

  if (!visible) return null;

  return (
    <Modal visible={visible} transparent animationType="slide">
      <View style={styles.modalOverlay}>
        <View style={styles.modalContent}>
          <Text style={styles.modalTitle}>💰 Ingreso General</Text>

          {/* SELECTOR DE FECHA */}
          <TouchableOpacity 
            style={styles.botonFecha}
            onPress={() => setMostrarCalendario(true)}
          >
            <Text style={styles.textoFecha}>📅 {formatearFecha(fecha)}</Text>
            <Text style={styles.textoCambiarFecha}>Cambiar fecha</Text>
          </TouchableOpacity>

          <SelectorFecha
            visible={mostrarCalendario}
            fechaInicial={fecha}
            onSeleccionar={(nuevaFecha) => {
              setFecha(nuevaFecha);
              setMostrarCalendario(false);
            }}
            onCancelar={() => setMostrarCalendario(false)}
          />

          {/* DESCRIPCIÓN */}
          <Text style={styles.label}>Descripción</Text>
          <TextInput
            style={styles.input}
            value={descripcion}
            onChangeText={setDescripcion}
            placeholder="Ej: Pago cliente, Transferencia, etc."
          />

          {/* MONTO */}
          <Text style={styles.label}>Monto ($)</Text>
          <TextInput
            style={styles.input}
            value={monto}
            onChangeText={setMonto}
            placeholder="0.00"
            keyboardType="decimal-pad"
          />

          {/* BILLETERA */}
          <Text style={styles.label}>Billetera de Destino</Text>
          <ScrollView horizontal style={styles.listaApps}>
            {billeteras.map((b) => (
              <TouchableOpacity
                key={b.id}
                style={[
                  styles.botonApp,
                  billeteraId === b.id && styles.botonAppSeleccionado
                ]}
                onPress={() => setBilleteraId(b.id)}
              >
                <Text style={[
                  styles.textoApp,
                  billeteraId === b.id && styles.textoAppSeleccionado
                ]}>
                  {b.icono} {b.nombre}
                </Text>
              </TouchableOpacity>
            ))}
          </ScrollView>

          {/* BOTONES */}
          <View style={styles.modalButtons}>
            <TouchableOpacity style={styles.botonCancelar} onPress={onCancelar}>
              <Text style={styles.botonTexto}>Cancelar</Text>
            </TouchableOpacity>
            <TouchableOpacity style={styles.botonGuardar} onPress={handleGuardar}>
              <Text style={[styles.botonTexto, { color: '#fff' }]}>Guardar</Text>
            </TouchableOpacity>
          </View>
        </View>
      </View>
    </Modal>
  );
};

// ==================== COMPONENTE: REGISTRO DE GASTO GENERAL ====================
