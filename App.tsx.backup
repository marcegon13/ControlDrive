// ==================== COMPONENTE: HISTORIAL ====================
interface HistorialProps {
  registros: RegistroDiario[];
  cargas: CargaCombustible[];
  ingresos: IngresoGeneral[];
  gastos: GastoGeneral[];
  billeteras: Billetera[];
  onEliminarRegistro: (id: string) => void;
  onEliminarCarga: (id: string) => void;
  onEliminarIngreso: (id: string) => void;
  onEliminarGasto: (id: string) => void;
  onResetearTodo: () => void;
}

const Historial: React.FC<HistorialProps> = ({
  registros,
  cargas,
  ingresos,
  gastos,
  billeteras,
  onEliminarRegistro,
  onEliminarCarga,
  onEliminarIngreso,
  onEliminarGasto,
  onResetearTodo,
}) => {
  const todosRegistros = [
    ...registros.map(r => ({ ...r, tipo: 'viaje' as const })),
    ...cargas.map(c => ({ ...c, tipo: 'combustible' as const })),
    ...ingresos.map(i => ({ ...i, tipo: 'ingreso' as const })),
    ...gastos.map(g => ({ ...g, tipo: 'gasto' as const }))
  ].sort((a, b) => new Date(b.fecha).getTime() - new Date(a.fecha).getTime());

  const renderItem = ({ item }: any) => {
    const obtenerColor = () => {
      switch (item.tipo) {
        case 'viaje': return '#3498db';
        case 'combustible': return '#e67e22';
        case 'ingreso': return '#27ae60';
        case 'gasto': return '#e74c3c';
        default: return '#7f8c8d';
      }
    };

    const obtenerIcono = () => {
      switch (item.tipo) {
        case 'viaje': return '🚗';
        case 'combustible': return '⛽';
        case 'ingreso': return '💰';
        case 'gasto': return '💳';
        default: return '📝';
      }
    };

    const obtenerTitulo = () => {
      switch (item.tipo) {
        case 'viaje': return `${obtenerIcono()} ${item.app}`;
        case 'combustible': return `${obtenerIcono()} ${item.estacion}`;
        case 'ingreso': return `${obtenerIcono()} ${item.descripcion}`;
        case 'gasto': return `${obtenerIcono()} ${item.descripcion}`;
        default: return `${obtenerIcono()} Registro`;
      }
    };

    const handleEliminar = () => {
      Alert.alert(
        'Eliminar Registro',
        `¿Eliminar registro del ${formatearFecha(new Date(item.fecha))}?`,
        [
          { text: 'Cancelar', style: 'cancel' },
          {
            text: 'Eliminar',
            style: 'destructive',
            onPress: () => {
              switch (item.tipo) {
                case 'viaje':
                  onEliminarRegistro(item.id);
                  break;
                case 'combustible':
                  onEliminarCarga(item.id);
                  break;
                case 'ingreso':
                  onEliminarIngreso(item.id);
                  break;
                case 'gasto':
                  onEliminarGasto(item.id);
                  break;
              }
              Alert.alert('✅ Eliminado', 'Registro eliminado correctamente');
            }
          }
        ]
      );
    };

    return (
      <View style={[
        styles.cardHistorial,
        { borderLeftColor: obtenerColor() }
      ]}>
        <View style={styles.filaHistorial}>
          <View style={styles.infoHistorial}>
            <Text style={styles.tituloHistorial}>
              {obtenerTitulo()}
            </Text>
            <Text style={styles.fechaHistorial}>
              {formatearFecha(new Date(item.fecha))}
            </Text>
          </View>
          
          <View style={styles.derechaHistorial}>
            <Text style={[
              styles.montoHistorial,
              { color: item.tipo === 'gasto' ? '#e74c3c' : '#27ae60' }
            ]}>
              {item.tipo === 'gasto' ? '-' : '+'}{formatearMoneda(item.tipo === 'viaje' ? item.total : item.monto)}
            </Text>
            <TouchableOpacity onPress={handleEliminar} style={styles.botonEliminarContainer}>
              <Text style={styles.botonEliminar}>🗑️</Text>
            </TouchableOpacity>
          </View>
        </View>
        
        {item.tipo === 'viaje' ? (
          <View style={styles.detallesViaje}>
            <Text style={styles.detalle}>💵 {formatearMoneda(item.efectivo)}</Text>
            <Text style={styles.detalle}>💳 {formatearMoneda(item.tarjetas)}</Text>
            <Text style={styles.detalle}>📱 {formatearMoneda(item.mercadoPago)}</Text>
          </View>
        ) : item.tipo === 'combustible' ? (
          <View style={styles.detallesCombustible}>
            <Text style={styles.detalle}>{item.litros}L</Text>
            <Text style={styles.detalle}>{formatearMoneda(item.precioPorLitro)}/L</Text>
            <Text style={styles.detalle}>
              Pagado con: {billeteras.find(b => b.id === item.billeteraId)?.nombre}
            </Text>
          </View>
        ) : item.tipo === 'ingreso' ? (
          <View style={styles.detallesGeneral}>
            <Text style={styles.detalle}>
              Billetera: {billeteras.find(b => b.id === item.billeteraId)?.nombre}
            </Text>
          </View>
        ) : item.tipo === 'gasto' ? (
          <View style={styles.detallesGeneral}>
            <Text style={styles.detalle}>Categoría: {item.categoria}</Text>
            <Text style={styles.detalle}>
              Billetera: {billeteras.find(b => b.id === item.billeteraId)?.nombre}
            </Text>
          </View>
        ) : null}
      </View>
    );
  };

  return (
    <View style={styles.historialContainer}>
      <View style={styles.headerHistorial}>
        <Text style={styles.tituloSeccion}>📋 Historial Completo</Text>
        <TouchableOpacity 
          style={styles.botonResetTodo}
          onPress={onResetearTodo}
        >
          <Text style={styles.textoResetTodo}>🔄 Reset Todo</Text>
        </TouchableOpacity>
      </View>
      
      {todosRegistros.length === 0 ? (
        <View style={styles.vacioContainer}>
          <Text style={styles.iconoVacio}>📭</Text>
          <Text style={styles.textoVacio}>No hay registros</Text>
          <Text style={styles.subtextoVacio}>
            Usa las Acciones Rápidas para agregar registros
          </Text>
        </View>
      ) : (
        <FlatList
          data={todosRegistros}
          keyExtractor={(item) => item.id}
          renderItem={renderItem}
          contentContainerStyle={styles.listaHistorial}
        />
      )}
    </View>
  );
};

// ==================== APP PRINCIPAL ====================
export default function App() {
  // ESTADOS PRINCIPALES
  const [billeteras, setBilleteras] = useState<Billetera[]>(BILLETERAS_INICIALES);
  const [registros, setRegistros] = useState<RegistroDiario[]>([]);
  const [cargas, setCargas] = useState<CargaCombustible[]>([]);
  const [ingresosGenerales, setIngresosGenerales] = useState<IngresoGeneral[]>([]);
  const [gastosGenerales, setGastosGenerales] = useState<GastoGeneral[]>([]);
  
  // ESTADOS DE MODALES
  const [mostrarRegistroViajes, setMostrarRegistroViajes] = useState(false);
  const [mostrarRegistroCombustible, setMostrarRegistroCombustible] = useState(false);
  const [mostrarRegistroIngreso, setMostrarRegistroIngreso] = useState(false);
  const [mostrarRegistroGasto, setMostrarRegistroGasto] = useState(false);
  const [mostrarHistorial, setMostrarHistorial] = useState(false);

  // CARGAR DATOS AL INICIAR
  useEffect(() => {
    cargarDatos();
  }, []);

  // GUARDAR DATOS CUANDO CAMBIAN
  useEffect(() => {
    guardarDatos();
  }, [billeteras, registros, cargas, ingresosGenerales, gastosGenerales]);

  const cargarDatos = async () => {
    try {
      const [
        savedBilleteras, 
        savedRegistros, 
        savedCargas,
        savedIngresos,
        savedGastos
      ] = await Promise.all([
        AsyncStorage.getItem(STORAGE_KEYS.BILLETERAS),
        AsyncStorage.getItem(STORAGE_KEYS.REGISTROS),
        AsyncStorage.getItem(STORAGE_KEYS.CARGAS),
        AsyncStorage.getItem(STORAGE_KEYS.INGRESOS),
        AsyncStorage.getItem(STORAGE_KEYS.GASTOS),
      ]);

      // CÓDIGO TEMPORAL: RESETEAR BILLETERAS A 0
      // Eliminar los datos guardados de billeteras para empezar desde 0
      await AsyncStorage.removeItem(STORAGE_KEYS.BILLETERAS);
      
      // Usar siempre los valores iniciales (0)
      setBilleteras(BILLETERAS_INICIALES);
      
      if (savedRegistros) setRegistros(JSON.parse(savedRegistros).map((r: any) => ({
        ...r,
        fecha: new Date(r.fecha),
        fechaRegistro: new Date(r.fechaRegistro)
      })));
      if (savedCargas) setCargas(JSON.parse(savedCargas).map((c: any) => ({
        ...c,
        fecha: new Date(c.fecha),
        fechaRegistro: new Date(c.fechaRegistro)
      })));
      if (savedIngresos) setIngresosGenerales(JSON.parse(savedIngresos).map((i: any) => ({
        ...i,
        fecha: new Date(i.fecha),
        fechaRegistro: new Date(i.fechaRegistro)
      })));
      if (savedGastos) setGastosGenerales(JSON.parse(savedGastos).map((g: any) => ({
        ...g,
        fecha: new Date(g.fecha),
        fechaRegistro: new Date(g.fechaRegistro)
      })));
    } catch (error) {
      console.error('Error cargando datos:', error);
      // En caso de error, usar valores iniciales
      setBilleteras(BILLETERAS_INICIALES);
    }
  };

  const guardarDatos = async () => {
    try {
      await Promise.all([
        AsyncStorage.setItem(STORAGE_KEYS.BILLETERAS, JSON.stringify(billeteras)),
        AsyncStorage.setItem(STORAGE_KEYS.REGISTROS, JSON.stringify(registros)),
        AsyncStorage.setItem(STORAGE_KEYS.CARGAS, JSON.stringify(cargas)),
        AsyncStorage.setItem(STORAGE_KEYS.INGRESOS, JSON.stringify(ingresosGenerales)),
        AsyncStorage.setItem(STORAGE_KEYS.GASTOS, JSON.stringify(gastosGenerales)),
      ]);
    } catch (error) {
      console.error('Error guardando datos:', error);
    }
  };

  // FUNCIÓN PARA RESETEAR LAS BILLETERAS A 0
  const resetearSaldos = () => {
    Alert.alert(
      '🔄 Resetear Saldos',
      '¿Resetear los saldos de todas las billeteras a 0?\n\nLos registros no se borrarán.',
      [
        { text: 'Cancelar', style: 'cancel' },
        {
          text: 'Resetear Saldos',
          onPress: () => {
            setBilleteras(BILLETERAS_INICIALES);
            Alert.alert('✅ Éxito', 'Saldos reseteados a 0');
          }
        }
      ]
    );
  };

  // FUNCIÓN PARA RESETEAR TODO
  const resetearTodo = () => {
    Alert.alert(
      '⚠️ Resetear Todo',
      '¿Estás seguro de que querés resetear TODOS los datos?\n\nEsto borrará todos los registros y saldos.',
      [
        { text: 'Cancelar', style: 'cancel' },
        {
          text: 'Resetear Todo',
          style: 'destructive',
          onPress: async () => {
            try {
              await Promise.all([
                AsyncStorage.removeItem(STORAGE_KEYS.BILLETERAS),
                AsyncStorage.removeItem(STORAGE_KEYS.REGISTROS),
                AsyncStorage.removeItem(STORAGE_KEYS.CARGAS),
                AsyncStorage.removeItem(STORAGE_KEYS.INGRESOS),
                AsyncStorage.removeItem(STORAGE_KEYS.GASTOS),
              ]);
              
              setBilleteras(BILLETERAS_INICIALES);
              setRegistros([]);
              setCargas([]);
              setIngresosGenerales([]);
              setGastosGenerales([]);
              
              Alert.alert('✅ Éxito', 'Todos los datos han sido reseteados');
            } catch (error) {
              Alert.alert('❌ Error', 'No se pudieron resetear los datos');
            }
          }
        }
      ]
    );
  };

  // HANDLERS PARA REGISTROS
  const handleGuardarRegistro = (nuevoRegistro: Omit<RegistroDiario, 'id' | 'fechaRegistro'>) => {
    const registroCompleto: RegistroDiario = {
      ...nuevoRegistro,
      id: Date.now().toString(),
      fechaRegistro: new Date()
    };

    setRegistros([registroCompleto, ...registros]);
    
    // Actualizar saldos de billeteras
    setBilleteras(prev => prev.map(b => {
      if (b.nombre === 'Efectivo') {
        return { ...b, saldo: b.saldo + nuevoRegistro.efectivo };
      } else if (b.nombre === 'Tarjetas/Plataforma') {
        return { ...b, saldo: b.saldo + nuevoRegistro.tarjetas };
      } else if (b.nombre === 'Mercado Pago') {
        return { ...b, saldo: b.saldo + nuevoRegistro.mercadoPago };
      }
      return b;
    }));

    setMostrarRegistroViajes(false);
    Alert.alert('✅ Éxito', 'Viaje registrado correctamente');
  };

  const handleGuardarCarga = (nuevaCarga: Omit<CargaCombustible, 'id' | 'fechaRegistro'>) => {
    const cargaCompleta: CargaCombustible = {
      ...nuevaCarga,
      id: Date.now().toString(),
      fechaRegistro: new Date()
    };

    setCargas([cargaCompleta, ...cargas]);
    
    // Actualizar saldo de billetera usada
    setBilleteras(prev => prev.map(b => 
      b.id === nuevaCarga.billeteraId 
        ? { ...b, saldo: b.saldo - nuevaCarga.total }
        : b
    ));

    setMostrarRegistroCombustible(false);
    Alert.alert('✅ Éxito', 'Carga de combustible registrada');
  };

  const handleGuardarIngreso = (nuevoIngreso: Omit<IngresoGeneral, 'id' | 'fechaRegistro'>) => {
    const ingresoCompleto: IngresoGeneral = {
      ...nuevoIngreso,
      id: Date.now().toString(),
      fechaRegistro: new Date()
    };

    setIngresosGenerales([ingresoCompleto, ...ingresosGenerales]);
    
    // Actualizar saldo de billetera
    setBilleteras(prev => prev.map(b => 
      b.id === nuevoIngreso.billeteraId 
        ? { ...b, saldo: b.saldo + nuevoIngreso.monto }
        : b
    ));

    setMostrarRegistroIngreso(false);
    Alert.alert('✅ Éxito', 'Ingreso registrado correctamente');
  };

  const handleGuardarGasto = (nuevoGasto: Omit<GastoGeneral, 'id' | 'fechaRegistro'>) => {
    const gastoCompleto: GastoGeneral = {
      ...nuevoGasto,
      id: Date.now().toString(),
      fechaRegistro: new Date()
    };

    setGastosGenerales([gastoCompleto, ...gastosGenerales]);
    
    // Actualizar saldo de billetera
    setBilleteras(prev => prev.map(b => 
      b.id === nuevoGasto.billeteraId 
        ? { ...b, saldo: b.saldo - nuevoGasto.monto }
        : b
    ));

    setMostrarRegistroGasto(false);
    Alert.alert('✅ Éxito', 'Gasto registrado correctamente');
  };

  const handleEliminarRegistro = (id: string) => {
    const registro = registros.find(r => r.id === id);
    if (!registro) return;

    setRegistros(prev => prev.filter(r => r.id !== id));
    
    // Revertir saldos
    setBilleteras(prev => prev.map(b => {
      if (b.nombre === 'Efectivo') {
        return { ...b, saldo: b.saldo - registro.efectivo };
      } else if (b.nombre === 'Tarjetas/Plataforma') {
        return { ...b, saldo: b.saldo - registro.tarjetas };
      } else if (b.nombre === 'Mercado Pago') {
        return { ...b, saldo: b.saldo - registro.mercadoPago };
      }
      return b;
    }));
  };

  const handleEliminarCarga = (id: string) => {
    const carga = cargas.find(c => c.id === id);
    if (!carga) return;

    setCargas(prev => prev.filter(c => c.id !== id));
    
    // Revertir saldo
    setBilleteras(prev => prev.map(b => 
      b.id === carga.billeteraId 
        ? { ...b, saldo: b.saldo + carga.total }
        : b
    ));
  };

  const handleEliminarIngreso = (id: string) => {
    const ingreso = ingresosGenerales.find(i => i.id === id);
    if (!ingreso) return;

    setIngresosGenerales(prev => prev.filter(i => i.id !== id));
    
    // Revertir saldo
    setBilleteras(prev => prev.map(b => 
      b.id === ingreso.billeteraId 
        ? { ...b, saldo: b.saldo - ingreso.monto }
        : b
    ));
  };

  const handleEliminarGasto = (id: string) => {
    const gasto = gastosGenerales.find(g => g.id === id);
    if (!gasto) return;

    setGastosGenerales(prev => prev.filter(g => g.id !== id));
    
    // Revertir saldo
    setBilleteras(prev => prev.map(b => 
      b.id === gasto.billeteraId 
        ? { ...b, saldo: b.saldo + gasto.monto }
        : b
    ));
  };

  // NAVEGACIÓN
  const navegarA = (destino: 'dashboard' | 'historial') => {
    if (destino === 'dashboard') setMostrarHistorial(false);
    if (destino === 'historial') setMostrarHistorial(true);
  };

  return (
    <SafeAreaView style={styles.container}>
      {/* HEADER */}
      <View style={styles.appHeader}>
        <View style={styles.headerRow}>
          <View>
            <Text style={styles.appTitle}>🚗 Control Driver</Text>
            <Text style={styles.appSubtitle}>Gestión inteligente de ingresos</Text>
          </View>
          <TouchableOpacity 
            style={styles.botonReset}
            onPress={resetearSaldos}
          >
            <Text style={styles.textoReset}>🔄 Reset</Text>
          </TouchableOpacity>
        </View>
      </View>

      {/* NAVEGACIÓN */}
      <View style={styles.navegacion}>
        <TouchableOpacity 
          style={[styles.botonNav, !mostrarHistorial && styles.botonNavActivo]}
          onPress={() => navegarA('dashboard')}
        >
          <Text style={[styles.textoNav, !mostrarHistorial && styles.textoNavActivo]}>
            📊 Dashboard
          </Text>
        </TouchableOpacity>
        
        <TouchableOpacity 
          style={[styles.botonNav, mostrarHistorial && styles.botonNavActivo]}
          onPress={() => navegarA('historial')}
        >
          <Text style={[styles.textoNav, mostrarHistorial && styles.textoNavActivo]}>
            📋 Historial
          </Text>
        </TouchableOpacity>
      </View>

      {/* CONTENIDO PRINCIPAL */}
      <View style={styles.contenido}>
        {mostrarHistorial ? (
          <Historial
            registros={registros}
            cargas={cargas}
            ingresos={ingresosGenerales}
            gastos={gastosGenerales}
            billeteras={billeteras}
            onEliminarRegistro={handleEliminarRegistro}
            onEliminarCarga={handleEliminarCarga}
            onEliminarIngreso={handleEliminarIngreso}
            onEliminarGasto={handleEliminarGasto}
            onResetearTodo={resetearTodo}
          />
        ) : (
          <Dashboard
            registros={registros}
            cargas={cargas}
            billeteras={billeteras}
            onAbrirViajes={() => setMostrarRegistroViajes(true)}
            onAbrirCombustible={() => setMostrarRegistroCombustible(true)}
            onAbrirIngreso={() => setMostrarRegistroIngreso(true)}
            onAbrirGasto={() => setMostrarRegistroGasto(true)}
            onResetearSaldos={resetearSaldos}
          />
        )}
      </View>

      {/* BOTONES DE ACCIÓN FIJA */}
      <View style={styles.accionesFijas}>
        <TouchableOpacity 
          style={[styles.botonFijo, { backgroundColor: '#3498db' }]}
          onPress={() => setMostrarRegistroViajes(true)}
        >
          <Text style={styles.iconoFijo}>🚗</Text>
          <Text style={styles.textoFijo}>Viajes App</Text>
        </TouchableOpacity>
        
        <TouchableOpacity 
          style={[styles.botonFijo, { backgroundColor: '#e67e22' }]}
          onPress={() => setMostrarRegistroCombustible(true)}
        >
          <Text style={styles.iconoFijo}>⛽</Text>
          <Text style={styles.textoFijo}>Combustible</Text>
        </TouchableOpacity>
      </View>

      {/* MODALES */}
      <RegistroViajes
        visible={mostrarRegistroViajes}
        onGuardar={handleGuardarRegistro}
        onCancelar={() => setMostrarRegistroViajes(false)}
      />

      <RegistroCombustible
        visible={mostrarRegistroCombustible}
        billeteras={billeteras}
        onGuardar={handleGuardarCarga}
        onCancelar={() => setMostrarRegistroCombustible(false)}
      />

      <RegistroIngresoGeneral
        visible={mostrarRegistroIngreso}
        billeteras={billeteras}
        onGuardar={handleGuardarIngreso}
        onCancelar={() => setMostrarRegistroIngreso(false)}
      />

      <RegistroGastoGeneral
        visible={mostrarRegistroGasto}
        billeteras={billeteras}
        onGuardar={handleGuardarGasto}
        onCancelar={() => setMostrarRegistroGasto(false)}
      />
    </SafeAreaView>
  );
}

